# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (single user only)
# Get your ID by sending /start to your bot
TELEGRAM_USER_ID=your_telegram_user_id

# ActualBudget Server Configuration
# Server URL where ActualBudget is running
ACTUAL_SERVER_URL=http://actual:5006

# ActualBudget server password
ACTUAL_SERVER_PASSWORD=your_password

# Budget ID to use for transactions
# Find in ActualBudget Settings → Show advanced settings → Sync ID
BUDGET_ID=your_budget_id

# ActualBudget E2E encryption password (optional)
# Required only if your budget has end-to-end encryption enabled
ACTUAL_E2E_PASSWORD=your_e2e_password

# How many months back to look for uncategorized transactions (optional, default: 3)
# TRANSACTION_LOOKBACK_MONTHS=3
